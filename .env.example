# ── Required ──────────────────────────────────────────────────
# (none — the app works out of the box with zero config)

# ── Optional ──────────────────────────────────────────────────

# Your Heroku app name (e.g. my-crash-suite).
# Enables the keep-alive ping so the dyno never sleeps.
# HEROKU_APP_NAME=my-crash-suite

# Base64 session backup string.
# After first pairing, copy the string from the dashboard → Session Backup.
# Paste it here so your session survives every dyno restart.
# SESSION_DATA=eyJjcmVkcy5qc29uIjoiey4uLn0i...
